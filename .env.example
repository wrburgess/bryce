# Bryce environment configuration. Copy to .env (never committed) and fill in.
# All secrets come from the environment only — never commit real values.

# Path to the SQLite database file (created + migrated automatically on first run).
DATABASE_PATH=data/bryce.db

# Host timezone used for "today" (digest date_covered, season boundaries).
TZ=America/Chicago

# Mailer provider: postmark | smtp | console
MAILER_PROVIDER=postmark

# Required when MAILER_PROVIDER=postmark
POSTMARK_SERVER_TOKEN=

# Required when MAILER_PROVIDER=smtp (e.g. Forward Email)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# Digest recipients (required unless MAILER_PROVIDER=console)
DIGEST_TO=
DIGEST_FROM=

# Polite delay between MLB Stats API calls, in milliseconds.
MLB_API_DELAY_MS=500

# Polite delay between stats.ncaa.org scrape requests, in milliseconds.
NCAA_SCRAPE_DELAY_MS=3000

# Port for the health-check HTTP server.
SERVER_PORT=3000

# Bearer token guarding /api and /mcp (generate one: openssl rand -hex 32).
# The server fails closed and will not start without it (nothing is served,
# including /health). With a token set, /health stays public; /api and /mcp
# require it.
API_TOKEN=
