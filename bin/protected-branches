#!/usr/bin/env ruby
# frozen_string_literal: true

# bin/protected-branches — print the protected-branch list authored in PROJECT.md, one per line.
#
# The git hooks (bin/guard-protected-branch, .claude/hooks/enforce-branch-creation.sh) read a
# generated sidecar (.githooks/protected-branches); bin/install-git-hooks regenerates that sidecar by
# running this script. Parsing logic lives in scripts/protected_branches.rb so it is tested once.
#
# Usage:
#   ruby bin/protected-branches [--file PROJECT.md]
#     --file PATH   PROJECT.md to read (default: ./PROJECT.md).
#
# Exit status: 0 on success (even when the list is empty — callers apply a fail-closed default);
#              1 when the file does not exist.

require "optparse"
require_relative "../scripts/protected_branches"

file = "PROJECT.md"
OptionParser.new do |opts|
  opts.banner = "Usage: ruby bin/protected-branches [--file PROJECT.md]"
  opts.on("--file PATH", "PROJECT.md to read (default: ./PROJECT.md)") { |v| file = v }
end.parse!(ARGV)

unless File.file?(file)
  warn "protected-branches: no such file: #{file}"
  exit 1
end

puts ProtectedBranches.from_file(file)
