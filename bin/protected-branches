#!/usr/bin/env bash
#
# bin/protected-branches — print the protected-branch list authored in PROJECT.md, one per line.
#
# Thin shim over the TypeScript CLI (scripts/protected-branches.ts, run via tsx — ADR 0039). This
# path is kept deliberately: the parity check's GUARDRAIL_FILES invariant requires it, and callers
# (docs, ad-hoc use) still reach the list through `bin/protected-branches`. All parsing logic lives in
# scripts/protected-branches.ts so it is unit-tested once and reused by the parity check.
#
# Usage:
#   bin/protected-branches [--file PROJECT.md]
#     --file PATH   PROJECT.md to read (default: ./PROJECT.md).
#
# Exit status: 0 on success (even when the list is empty — callers apply a fail-closed default);
#              1 when the file does not exist.

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
exec "$REPO_ROOT/node_modules/.bin/tsx" "$REPO_ROOT/scripts/protected-branches.ts" "$@"
