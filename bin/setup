#!/usr/bin/env bash
#
# bin/setup — minimal, business-neutral setup for the Config Bundle.
#
# The only baseline setup step is activating the protected-branch git hooks (issue #6 / ADR 0009): on
# a fresh clone the hooks are inactive until core.hooksPath is set, so this must run once. A Host App
# with its own richer bin/setup (e.g. a Rails app's `bundle install` / `db:prepare`) keeps it —
# bin/ai-config-sync PRESERVES an existing bin/setup on re-sync (like PROJECT.md), so vendoring never
# clobbers the host's version. When adopting the bundle, add `bin/install-git-hooks` to that existing
# setup script.

set -euo pipefail

# Resolve the repo root from this script's location so setup works from any cwd (the old Ruby
# Dir.chdir(APP_ROOT) behavior), then run from there.
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

echo "== Installing git hooks (protected-branch guard) =="
exec bin/install-git-hooks
